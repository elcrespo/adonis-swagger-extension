{
  "name": "adonis-swagger-extension",
  "version": "1.3.0",
  "description": "Adonis v5 Swagger extension with ts-morph",
  "main": "build/providers/SwaggerProvider.js",
  "types": "build/adonis-typings/index.d.ts",
  "files": [
    "build/adonis-typings",
    "build/providers",
    "build/src",
    "build/commands",
    "build/instructions.js",
    "build/instructions.md",
    "build/templates",
    "src",
    "providers",
    "adonis-typings"
  ],
  "scripts": {
    "clean": "del-cli build",
    "compile": "npm run clean && tsc && copyfiles -u 1 templates/config.txt build/templates",
    "build": "npm run compile",
    "prepublishOnly": "npm run build",
    "commit": "git-cz",
    "release": "np --message=\"chore(release): %s\"",
    "version": "npm run build",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "np": {
    "contents": ".",
    "anyBranch": false
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "dependencies": {
    "swagger-ui-dist": "^5.11.0",
    "ts-morph": "^21.0.1",
    "yaml": "^2.3.4"
  },
  "peerDependencies": {
    "@adonisjs/core": "^5.8.0"
  },
  "devDependencies": {
    "@adonisjs/core": "^5.8.0",
    "@adonisjs/mrm-preset": "^5.0.3",
    "@adonisjs/sink": "^5.4.3",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@types/node": "^20.10.4",
    "@types/swagger-ui-dist": "^3.30.6",
    "copyfiles": "^2.4.1",
    "cz-conventional-changelog": "^3.3.0",
    "del-cli": "^5.1.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "np": "^11.0.2",
    "semantic-release": "^24.2.9",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "adonisjs": {
    "instructions": "./build/instructions.js",
    "instructionsMd": "./build/instructions.md",
    "types": "adonis-swagger-extension",
    "providers": [
      "adonis-swagger-extension"
    ],
    "commands": [
      "./build/commands/SwaggerEject.js"
    ],
    "templates": {
      "config": [
        {
          "src": "config.txt",
          "dest": "swagger"
        }
      ]
    }
  }
}
